# ------------------------------------------------------
# pnpm configuration
# ------------------------------------------------------

# Enforce lockfile consistency.
# Installation fails if pnpm-lock.yaml is out of sync.
prefer-frozen-lockfile=true

# Better compatibility with VSCode ecosystem tooling
node-linker=hoisted

# Avoid implicit dependency leakage
shamefully-hoist=false

# Workspace support
link-workspace-packages=true

# Disable automatic pre/post lifecycle wrappers
enable-pre-post-scripts=false

# Helps avoid noisy peer dependency failures
auto-install-peers=true
strict-peer-dependencies=false
